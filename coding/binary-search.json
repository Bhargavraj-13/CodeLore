{
  "id": "binary-search",
  "topic": "binary-search",
  "title": "Search in Rotated Sorted Array",
  "difficulty": "intermediate",

  "problemStatement": "You are given a rotated sorted array and a target value. Return the index of the target if found, otherwise return -1.",

  "inputDescription": "A rotated sorted array of integers and a target integer",
  "outputDescription": "Index of target element or -1",

  "constraints": {
    "n": "1 ≤ n ≤ 100000",
    "values": "-10000 ≤ nums[i] ≤ 10000"
  },

  "evaluation": {
    "type": "function",
    "expectedFunction": {
      "python": "search",
      "cpp": "search"
    },
    "outputType": "integer"
  },

  "testCases": {
    "public": [
      {
        "input": {
          "nums": [4,5,6,7,0,1,2],
          "target": 0
        },
        "output": 4
      }
    ],
    "private": [
      { "input": { "nums": [4,5,6,7,0,1,2], "target": 3 }, "output": -1 },
      { "input": { "nums": [1], "target": 1 }, "output": 0 },
      { "input": { "nums": [1], "target": 0 }, "output": -1 },
      { "input": { "nums": [3,1], "target": 1 }, "output": 1 },
      { "input": { "nums": [5,1,3], "target": 5 }, "output": 0 },
      { "input": { "nums": [6,7,1,2,3,4,5], "target": 4 }, "output": 5 },
      { "input": { "nums": [2,3,4,5,6,7,1], "target": 1 }, "output": 6 },
      { "input": { "nums": [1,2,3,4,5], "target": 3 }, "output": 2 },
      { "input": { "nums": [1,2,3,4,5], "target": 6 }, "output": -1 }
    ]
  },

  "notes": "Array contains no duplicates."
}
