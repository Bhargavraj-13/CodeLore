  "description": "Given a linked list, print all its elements in order separated by spaces.",

  "starterCode": {
    "cpp": "#include <iostream>\n#include <vector>\nusing namespace std;\n\nint main() {\n    int n;\n    cin >> n;\n\n    vector<int> values(n);\n    for (int i = 0; i < n; i++) cin >> values[i];\n\n    // write your code here\n\n    return 0;\n}",
