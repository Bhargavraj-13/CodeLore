{
  "id": "two-pointers",
  "topic": "two-pointers",
  "title": "Two Sum II (Sorted Array)",
  "difficulty": "intermediate",

  "problemStatement": "Given a sorted array of integers, find two numbers such that they add up to a specific target. Return their 1-based indices. You may assume exactly one solution exists.",

  "inputDescription": "A sorted array of integers and a target integer",
  "outputDescription": "An array containing the 1-based indices of the two numbers",

  "constraints": {
    "n": "2 ≤ n ≤ 100000",
    "values": "-1000 ≤ numbers[i] ≤ 1000"
  },

  "evaluation": {
    "type": "function",
    "expectedFunction": {
      "python": "twoSum",
      "cpp": "twoSum"
    },
    "outputType": "array"
  },

  "testCases": {
    "public": [
      {
        "input": {
          "numbers": [2,7,11,15],
          "target": 9
        },
        "output": [1,2]
      }
    ],
    "private": [
      { "input": { "numbers": [1,2,3,4,4], "target": 8 }, "output": [4,5] },
      { "input": { "numbers": [-3,-1,0,2,4], "target": 1 }, "output": [2,5] },
      { "input": { "numbers": [0,0,3,4], "target": 0 }, "output": [1,2] },
      { "input": { "numbers": [1,3,5,7], "target": 8 }, "output": [1,4] },
      { "input": { "numbers": [2,3], "target": 5 }, "output": [1,2] },
      { "input": { "numbers": [-5,-3,-1,0,2], "target": -4 }, "output": [1,3] },
      { "input": { "numbers": [1,2,3,9], "target": 11 }, "output": [2,4] },
      { "input": { "numbers": [5,25,75], "target": 100 }, "output": [2,3] },
      { "input": { "numbers": [1,1,1,2], "target": 3 }, "output": [3,4] }
    ]
  },

  "notes": "Array is sorted; solution should run in O(n) time."
}
