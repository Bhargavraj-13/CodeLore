{
  "id": "dynamic-programming",
  "topic": "dynamic-programming",
  "title": "Coin Change",
  "difficulty": "intermediate",

  "problemStatement": "Given an array of coin denominations and an amount, return the minimum number of coins needed to make up that amount. If it is not possible, return -1.",

  "inputDescription": "An array of coin denominations and a target amount",
  "outputDescription": "Minimum number of coins required or -1",

  "constraints": {
    "n": "1 ≤ coins.length ≤ 12",
    "amount": "0 ≤ amount ≤ 10000"
  },

  "evaluation": {
    "type": "function",
    "expectedFunction": {
      "python": "coinChange",
      "cpp": "coinChange"
    },
    "outputType": "integer"
  },

  "testCases": {
    "public": [
      {
        "input": {
          "coins": [1,2,5],
          "amount": 11
        },
        "output": 3
      }
    ],
    "private": [
      { "input": { "coins": [2], "amount": 3 }, "output": -1 },
      { "input": { "coins": [1], "amount": 0 }, "output": 0 },
      { "input": { "coins": [1], "amount": 2 }, "output": 2 },
      { "input": { "coins": [2,5,10], "amount": 27 }, "output": 4 },
      { "input": { "coins": [3,7], "amount": 5 }, "output": -1 },
      { "input": { "coins": [1,3,4], "amount": 6 }, "output": 2 },
      { "input": { "coins": [5,10,25], "amount": 30 }, "output": 2 },
      { "input": { "coins": [2,4], "amount": 8 }, "output": 2 },
      { "input": { "coins": [1], "amount": 10000 }, "output": 10000 }
    ]
  },

  "notes": "Unlimited coins of each denomination are available."
}
