      "difficulty": "intermediate",
      "problemStatement": "Given the head of a linked list, determine whether the list contains a cycle. A cycle exists if a node can be revisited by continuously following the next pointer.",
      "evaluation": {
        "type": "function",
        "expectedFunction": {
          "python": "hasCycle",
          "cpp": "hasCycle"
        },
        "outputType": "boolean"
